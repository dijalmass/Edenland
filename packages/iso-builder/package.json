{
  "name": "@edenland/iso-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "pre-build": "mkdir -p airootfs/usr/bin && cp ../../apps/shell/src-tauri/target/release/edenland airootfs/usr/bin/edenland",
    "build:iso": "bun run pre-build && sudo -E mkarchiso -v -w ./work -o ./out .",
    "clean": "sudo rm -rf ./work ./out"
  },
  "devDependencies": {
    "@edenland/edenland": "workspace:*"
  }
}
